# ARD EVENT PLATFORM - Next.js + Neon
# Copy to .env.local and fill real values.

# Neon / PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/ard_event?sslmode=require"

# Public app URL, used for links inside PDFs/messages
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000

# Admin
ADMIN_PIN=your_admin_pin
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ClickUp CRM
CLICKUP_API_KEY=pk_YOUR_CLICKUP_API_KEY
CLICKUP_LIST_ID=YOUR_CLICKUP_LIST_ID
CLICKUP_TEAM_ID=YOUR_CLICKUP_TEAM_ID

# Zapier Webhook
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ID/YOUR_HOOK/

# Email (Nodemailer - Gmail App Password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alibinnadeem.ai@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="ARD Developers <alibinnadeem.ai@gmail.com>"

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
