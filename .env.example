# ARD EVENT PLATFORM - Next.js + Neon
# Copy to .env.local and fill real values.

# Neon / PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST/ard_event?sslmode=require"

# Public app URL, used for links inside PDFs/messages
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000

# Admin (CRM /admin page)
ADMIN_PIN=your_admin_pin
# Lucky draw operator (raffle controls) - independent password from ADMIN_PIN
RAFFLE_PIN=your_raffle_pin
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ClickUp CRM
CLICKUP_API_KEY=pk_YOUR_CLICKUP_API_KEY
CLICKUP_LIST_ID=YOUR_CLICKUP_LIST_ID
CLICKUP_TEAM_ID=YOUR_CLICKUP_TEAM_ID

# Zapier Webhook
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ID/YOUR_HOOK/

# Email (Nodemailer - Zoho SMTP)
# Zoho free custom-domain mailboxes use smtp.zoho.com.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@alibinnadeem.com
SMTP_PASS=your_zoho_mailbox_password
EMAIL_FROM="ARD Developers <info@alibinnadeem.com>"

# WhatsApp (360Messenger)
# Connect your number via QR in the 360Messenger dashboard, then copy the
# key from "Web Service Information".
MESSENGER360_API_KEY=YOUR_360MESSENGER_API_KEY

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
